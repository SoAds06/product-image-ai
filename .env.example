# Application Settings
APP_NAME=Product Image AI
APP_VERSION=3.0.0
DEBUG=false
LOG_LEVEL=INFO

# Folder Paths
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=processed
TEMP_FOLDER=/tmp/product-image-ai

# Canvas Configuration
CANVAS_WIDTH=1200
CANVAS_HEIGHT=1500
DEFAULT_SCALE=92
BACKGROUND_R=236
BACKGROUND_G=236
BACKGROUND_B=236

# Processing Configuration
MAX_WORKERS=8
MODEL_NAME=birefnet-general
REQUEST_TIMEOUT=30
DOWNLOAD_CHUNK_SIZE=8192

# Job Management
JOB_RETENTION_DAYS=7
MAX_RETRIES=3

# Feature Flags
ENABLE_GPU=true
CLEANUP_ON_DELETE=true
